	counts SUSY 234 +- 3.3
	select Pt(goodLepts) > 25
	counts SUSY 215 +- 3.2
	select Size(goodJets) >= 4 && Size(goodJets) < 6
	counts SUSY 35.5 +- 1.3
	select Size(bjet) == 0
	counts SUSY 26.4 +- 1.1
	select MET > 300
	counts SUSY 23.6 +- 1.1
	select ratio > 0.2
	counts SUSY 13.8 +- 0.8
	select AnaAplanarity > 0.01
	counts SUSY 12.5 +- 0.8
	select Meff > 1000
	counts SUSY 12.5 +- 0.8
	select MTL [] 150 520
	counts SUSY 6.9 +- 0.6
	bin Meff [] 1000 1600
